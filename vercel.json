{
  "buildCommand": "cd Bachelo && npm run build",
  "outputDirectory": "Bachelo/.next",
  "installCommand": "cd Bachelo && npm install",
  "devCommand": "cd Bachelo && npm run dev",
  "crons": [
    {
      "path": "/api/cleanup",
      "schedule": "0 0 * * *"
    }
  ],
  "functions": {
    "Bachelo/app/api/voice/upload/route.ts": {
      "maxDuration": 30
    },
    "Bachelo/app/api/board/upload/route.ts": {
      "maxDuration": 30
    }
  }
}